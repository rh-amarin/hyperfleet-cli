    {
      "script": "hf.maestro.bundles.sh",
      "description": "List maestro resource bundles via HTTP API",
      "config_requires": ["maestro-http-endpoint"],
      "tool_deps": ["jq"],
      "api_endpoint": "/api/maestro/v1/resource-bundles",
      "executions": [
        {
          "scenario": "list_bundles",
          "args": [],
          "exit_code": 0,
          "output_format": "json",
          "response_shape": {
            "items": [{
              "id": "UUID",
              "kind": "ResourceBundle",
              "consumer_name": "string",
              "manifests": "array of k8s manifests",
              "manifest_configs": "array of feedback/update configs",
              "metadata": "object with labels and annotations",
              "status": {
                "conditions": "array",
                "resourceStatus": "array of per-manifest status"
              }
            }],
            "kind": "ResourceBundleList"
          },
          "notes": "Contains full k8s manifest content, metadata labels/annotations, and per-resource feedback status"
        }
      ]
    },
    {
      "script": "hf.maestro.consumers.sh",
      "description": "List maestro consumers via HTTP API",
      "config_requires": ["maestro-http-endpoint"],
      "tool_deps": ["jq"],
      "api_endpoint": "/api/maestro/v1/consumers",
      "executions": [
        {
          "scenario": "list_consumers",
          "args": [],
          "exit_code": 0,
          "response": {
            "items": [{"id": "ec33113d-c705-4c36-a0c8-d857a189692a", "kind": "Consumer", "name": "cluster1"}],
            "kind": "ConsumerList",
            "total": 1
          }
        }
      ]
    },
    {
      "script": "hf.maestro.get.sh",
      "description": "Get maestro resource by name or interactive selection",
      "args_spec": "[name]",
      "config_requires": ["maestro-consumer", "maestro-http-endpoint", "maestro-grpc-endpoint"],
      "tool_deps": ["maestro-cli", "jq"],
      "notes": "Interactive menu if no name provided"
    },
    {
      "script": "hf.maestro.delete.sh",
      "description": "Delete maestro resource by name or interactive selection",
      "args_spec": "[name]",
      "config_requires": ["maestro-consumer", "maestro-http-endpoint", "maestro-grpc-endpoint"],
      "tool_deps": ["maestro-cli", "jq"],
      "notes": "Interactive menu if no name provided"

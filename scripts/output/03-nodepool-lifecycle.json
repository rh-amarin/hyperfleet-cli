{
  "group": "nodepool",
  "description": "NodePool CRUD lifecycle commands (always scoped to current cluster)",
  "prerequisite": "cluster-id must be set (via hf.cluster.create.sh or hf.cluster.search.sh)",
  "commands": [
    {
      "script": "hf.nodepool.create.sh",
      "description": "Create one or more nodepools in the current cluster",
      "args_spec": "<name> [count] [instance-type]",
      "defaults": {"name": "my-nodepool", "count": 1, "instance_type": "m4"},
      "config_requires": ["api-url", "api-version", "cluster-id"],
      "tool_deps": ["jq"],
      "api_method": "POST",
      "api_endpoint": "/api/hyperfleet/v1/clusters/{cluster_id}/nodepools",
      "executions": [
        {
          "scenario": "create_multiple",
          "args": ["workers", "2", "n2-standard-4"],
          "exit_code": 0,
          "behavior": [
            "Creates 'count' nodepools with suffix -1, -2, etc.",
            "Each nodepool gets labels.counter = sequential number",
            "Sets nodepool-id to the LAST created nodepool",
            "spec includes platform.type and replicas: 1"
          ],
          "request_payload_per_pool": {
            "name": "workers-N",
            "labels": {"counter": "N"},
            "spec": {"counter": "N", "platform": {"type": "n2-standard-4"}, "replicas": 1}
          },
          "response_shape": {
            "id": "UUID",
            "kind": "NodePool",
            "generation": 1,
            "name": "workers-1",
            "owner_references": {"href": "/api/hyperfleet/v1/clusters/{cluster_id}", "id": "cluster_uuid", "kind": "Cluster"},
            "spec": {"counter": "1", "platform": {"type": "n2-standard-4"}, "replicas": 1},
            "status.conditions": [
              {"type": "Ready", "status": "False", "reason": "MissingRequiredAdapters"},
              {"type": "Available", "status": "False", "reason": "AdaptersNotAtSameGeneration"}
            ]
          }
        },
        {
          "scenario": "create_with_defaults",
          "args": [],
          "exit_code": 0,
          "behavior": ["Creates 1 nodepool named 'my-nodepool-1' with type 'm4'"],
          "notes": "No args does NOT show usage - creates with defaults"
        }
      ]
    },
    {
      "script": "hf.nodepool.list.sh",
      "description": "List all nodepools in the current cluster",
      "args_spec": "[cluster_id]",
      "config_requires": ["api-url", "api-version", "cluster-id"],
      "tool_deps": ["jq"],
      "api_method": "GET",
      "api_endpoint": "/api/hyperfleet/v1/clusters/{cluster_id}/nodepools",
      "executions": [
        {
          "scenario": "list_nodepools",
          "args": [],
          "exit_code": 0,
          "output_format": "json",
          "response_shape": {
            "kind": "NodePoolList",
            "items": "array of NodePool objects",
            "page": 1, "size": "integer", "total": "integer"
          }
        }
      ]
    },
    {
      "script": "hf.nodepool.search.sh",
      "description": "Search nodepool by name within current cluster, sets as current",
      "args_spec": "<name>",
      "config_requires": ["api-url", "api-version", "cluster-id"],
      "tool_deps": ["jq"],
      "executions": [
        {
          "scenario": "search_existing",
          "args": ["workers-1"],
          "exit_code": 0,
          "behavior": ["Searches nodepools by name within cluster", "Sets nodepool-id in config"],
          "output_format": "json_array"
        }
      ]
    },
    {
      "script": "hf.nodepool.get.sh",
      "description": "Get full nodepool details",
      "args_spec": "[nodepool_id]",
      "config_requires": ["api-url", "api-version", "cluster-id", "nodepool-id"],
      "tool_deps": ["jq"],
      "api_method": "GET",
      "api_endpoint": "/api/hyperfleet/v1/clusters/{cluster_id}/nodepools/{nodepool_id}",
      "executions": [
        {
          "scenario": "get_current",
          "args": [],
          "exit_code": 0,
          "output_format": "json"
        }
      ]
    },
    {
      "script": "hf.nodepool.patch.sh",
      "description": "Increment counter in spec or labels",
      "args_spec": "spec|labels [nodepool_id]",
      "config_requires": ["api-url", "api-version", "cluster-id", "nodepool-id"],
      "tool_deps": ["jq"],
      "api_method": "PATCH",
      "api_endpoint": "/api/hyperfleet/v1/clusters/{cluster_id}/nodepools/{nodepool_id}",
      "executions": [
        {
          "scenario": "patch_spec",
          "args": ["spec"],
          "exit_code": 0,
          "behavior": ["Fetches current nodepool", "Increments spec.counter", "PATCHes back", "Generation increments"]
        }
      ]
    },
    {
      "script": "hf.nodepool.conditions.sh",
      "description": "Get nodepool conditions with generation",
      "args_spec": "[-w] [nodepool_id]",
      "config_requires": ["api-url", "api-version", "cluster-id", "nodepool-id"],
      "tool_deps": ["jq", "viddy (for -w)"],
      "executions": [
        {
          "scenario": "get_conditions",
          "args": [],
          "exit_code": 0,
          "response": {
            "generation": 2,
            "status": {
              "conditions": [
                {"type": "Ready", "status": "False", "reason": "MissingRequiredAdapters"},
                {"type": "Available", "status": "False", "reason": "AdaptersNotAtSameGeneration"}
              ]
            }
          }
        }
      ]
    },
    {
      "script": "hf.nodepool.conditions.table.sh",
      "description": "Display nodepool conditions in formatted table",
      "args_spec": "[nodepool_id]",
      "config_requires": ["api-url", "api-version", "cluster-id", "nodepool-id"],
      "tool_deps": ["jq"],
      "executions": [
        {
          "scenario": "before_adapter_status",
          "output": "TYPE       STATUS  LAST TRANSITION  REASON                       MESSAGE\nReady      False   -                MissingRequiredAdapters      ...\nAvailable  False   -                AdaptersNotAtSameGeneration  ..."
        },
        {
          "scenario": "after_all_adapters_report",
          "output": "TYPE                   STATUS  LAST TRANSITION  REASON                                              MESSAGE\nReady                  True    -                All required adapters reported Available=True...   ...\nAvailable              True    -                All required adapters report Available=True...     ...\nNpConfigmapSuccessful  True    -                ManualStatusPost                                  ...",
          "notes": "When all required adapters report True at current generation, Ready and Available flip to True"
        }
      ]
    },
    {
      "script": "hf.nodepool.statuses.sh",
      "description": "Get adapter statuses for a nodepool",
      "args_spec": "[-w] [nodepool_id]",
      "config_requires": ["api-url", "api-version", "cluster-id", "nodepool-id"],
      "tool_deps": ["jq", "viddy (for -w)"],
      "api_method": "GET",
      "api_endpoint": "/api/hyperfleet/v1/clusters/{cluster_id}/nodepools/{nodepool_id}/adapter-statuses",
      "executions": [
        {
          "scenario": "with_status",
          "args": [],
          "exit_code": 0,
          "response_shape": {
            "items": [{"adapter": "np-configmap", "conditions": "array", "observed_generation": 2}],
            "kind": "AdapterStatusList"
          }
        }
      ]
    },
    {
      "script": "hf.nodepool.delete.sh",
      "description": "Delete a nodepool",
      "args_spec": "[nodepool_id]",
      "config_requires": ["api-url", "api-version", "cluster-id", "nodepool-id"],
      "tool_deps": ["jq"],
      "api_method": "DELETE",
      "api_endpoint": "/api/hyperfleet/v1/clusters/{cluster_id}/nodepools/{nodepool_id}",
      "executions": [
        {
          "scenario": "delete_nodepool",
          "args": ["019dc049-e76c-7be1-b201-0db50e2c8ecb"],
          "exit_code": 0,
          "response_notes": "Returns full nodepool with deleted_by, deleted_time, incremented generation"
        }
      ]
    },
    {
      "script": "hf.nodepool.table.sh",
      "description": "List nodepools in table format with conditions",
      "args_spec": "[cluster_id]",
      "config_requires": ["api-url", "api-version", "cluster-id"],
      "tool_deps": ["jq"],
      "executions": [
        {
          "scenario": "with_data",
          "args": [],
          "exit_code": 0,
          "output": "ID                                    NAME       REPLICAS  TYPE           GEN  Available  NpConfigmapSuccessful  Ready\n---                                   ---        ---       ---            ---  ---        ---                    ---\n019dc049-e79e-72a9-94f8-0056a11193cd  workers-2  1         n2-standard-4  1    ●(red)     -                      ●(red)\n019dc049-e76c-7be1-b201-0db50e2c8ecb  workers-1  1         n2-standard-4  2    ●(green)   ●(green)               ●(green)",
          "notes": "Shows REPLICAS and TYPE columns unique to nodepools. Dynamic condition columns."
        }
      ]
    }
  ]
}
